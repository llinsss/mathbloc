{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "./contracts/dist"
  },
  "include": [
    "hardhat.config.ts",
    "contracts/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
